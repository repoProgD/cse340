<%- include('partials/header') %>

    <main>
        <h1>
            <%= title %>
        </h1>

        <h2>
            <%= project.title %>
        </h2>

        <p>
            Description: <%= project.description %>
        </p>

        <p>
            Date:
            <%= project.date.toLocaleDateString('en-US', { year: 'numeric' , month: 'long' , day: 'numeric' }) %>
        </p>

        <p>
            Location: <%= project.location %>
        </p>

        <p>
            Organization:
            <a href="/organization/<%= project.organization_id %>">
                <%= project.organization_name %>
            </a>
        </p>

        <h3>Categories</h3>

        <div>
            <% categories.forEach(category=> { %>
                <a href="/category/<%= category.category_id %>">
                    <%= category.name %>
                </a>
                <% }) %>
        </div>

        <p>
            <a href="/assign-categories/<%= project.project_id %>">
                Edit Categories
            </a>
        </p>

    </main>

    <%- include('partials/footer') %>